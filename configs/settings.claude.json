      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${TOKEN_ECONOMY_ROOT}/projects/agents-triage/hook.sh"
          }
        ]
      }
    ],
    "PreCompact": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${TOKEN_ECONOMY_ROOT}/hooks/pre-compact.sh"
          }
        ]
      }
    ]
