        "hooks": [
          {
            "type": "command",
            "command": "bash ${TOKEN_ECONOMY_ROOT}/hooks/session-start.sh"
          }
        ]
      }
    ],
    "UserPromptSubmit": [
      {
        "matcher": "*",
        "hooks": [
          {
            "type": "command",
            "command": "bash ${TOKEN_ECONOMY_ROOT}/hooks/user-prompt-submit.sh"
          }
        ]
