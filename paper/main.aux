\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Rate of positive $\Delta W$ (uniformity improvement) as a function of $M(p)/\sqrt  {p}$. Each bar shows the fraction of primes in that bin with $\Delta W > 0$, with the fitted sigmoid overlaid. The transition from $0\%$ to $100\%$ occurs sharply between $M/\sqrt  {p} \approx -0.1$ and $0.3$. Blue: $M < 0$ (almost no improvement); red: $M > 0$ (frequent improvement).}}{10}{figure.6}\protected@file@percent }
\newlabel{fig:sigmoid}{{6}{10}{Rate of positive $\Delta W$ (uniformity improvement) as a function of $M(p)/\sqrt {p}$. Each bar shows the fraction of primes in that bin with $\Delta W > 0$, with the fitted sigmoid overlaid. The transition from $0\%$ to $100\%$ occurs sharply between $M/\sqrt {p} \approx -0.1$ and $0.3$. Blue: $M < 0$ (almost no improvement); red: $M > 0$ (frequent improvement)}{figure.6}{}}
