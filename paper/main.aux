\newlabel{fig:farey-circle}{{1}{2}{The Farey sequence $\F _{12}$ on the unit circle: each fraction $a/b$ is placed at angle $2\pi a/b$. The pattern is strikingly uniform, with the largest gaps near $0$ and $1$ (top of the circle) where the denominators are smallest}{figure.1}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces Prime vs.\ composite insertion on the unit circle. \textbf  {Left:} adding prime $p = 13$ to $\mathcal  {F}_{12}$ inserts $12$ new fractions (red) at perfectly equispaced positions, filling every void. \textbf  {Right:} adding composite $N = 14$ inserts only $6$ new fractions (blue), leaving gaps where numerators share a factor with~$14$.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:circle}{{2}{3}{Prime vs.\ composite insertion on the unit circle. \textbf {Left:} adding prime $p = 13$ to $\F _{12}$ inserts $12$ new fractions (red) at perfectly equispaced positions, filling every void. \textbf {Right:} adding composite $N = 14$ inserts only $6$ new fractions (blue), leaving gaps where numerators share a factor with~$14$}{figure.2}{}}
