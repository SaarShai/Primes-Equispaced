\@writefile{lof}{\contentsline {figure}{\numberline {4}{\ignorespaces The universal formula for $\mathcal  {F}_{20}$. \textbf  {Top:} The Farey exponential sum at each frequency $m$. Green bars (primes $m > 20$) all equal $M(20)+1 = -2$---they are \emph  {identical}, independent of which prime. Blue bars (primes $m \le 20$) and orange bars (composites) vary. \textbf  {Bottom:} prime indicator. The dashed line at $m = N = 20$ separates the two regimes.}}{6}{figure.4}\protected@file@percent }
\newlabel{fig:universal}{{4}{6}{The universal formula for $\F _{20}$. \textbf {Top:} The Farey exponential sum at each frequency $m$. Green bars (primes $m > 20$) all equal $M(20)+1 = -2$---they are \emph {identical}, independent of which prime. Blue bars (primes $m \le 20$) and orange bars (composites) vary. \textbf {Bottom:} prime indicator. The dashed line at $m = N = 20$ separates the two regimes}{figure.4}{}}
