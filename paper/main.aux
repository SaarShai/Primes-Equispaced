\@writefile{lof}{\contentsline {figure}{\numberline {6}{\ignorespaces Per-prime wobble change $\Delta W(p)$ for all primes up to $p = 20{,}000$. Red bars: $\Delta W > 0$ (violations, uniformity improves). Blue bars: $\Delta W < 0$ (uniformity worsens). The burst--quiet pattern is visible: violations cluster in bands corresponding to positive Mertens excursions.}}{8}{figure.6}\protected@file@percent }
\newlabel{fig:delta-w}{{6}{8}{Per-prime wobble change $\Delta W(p)$ for all primes up to $p = 20{,}000$. Red bars: $\Delta W > 0$ (violations, uniformity improves). Blue bars: $\Delta W < 0$ (uniformity worsens). The burst--quiet pattern is visible: violations cluster in bands corresponding to positive Mertens excursions}{figure.6}{}}
