\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces The Bridge Identity visualized. Each Farey fraction $f \in \mathcal  {F}_{p-1}$ becomes a point at angle $2\pi pf$ on the unit circle. Their vector sum (red arrow) equals $M(p) + 2$. \textbf  {Left:} $p = 11$, $M = -2$, sum $= 0$ (vectors cancel). \textbf  {Right:} $p = 97$, $M = 1$, sum $= 3$ (net rightward bias).}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:bridge-vectors}{{5}{7}{The Bridge Identity visualized. Each Farey fraction $f \in \F _{p-1}$ becomes a point at angle $2\pi pf$ on the unit circle. Their vector sum (red arrow) equals $M(p) + 2$. \textbf {Left:} $p = 11$, $M = -2$, sum $= 0$ (vectors cancel). \textbf {Right:} $p = 97$, $M = 1$, sum $= 3$ (net rightward bias)}{figure.5}{}}
