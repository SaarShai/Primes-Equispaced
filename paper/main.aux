\@writefile{lof}{\contentsline {figure}{\numberline {5}{\ignorespaces Mertens bias visualized on the circle. Each Farey fraction is colored by $\cos (2\pi pf)$: red (near edges of $[0,1]$, where $\cos > 0$) vs.\ blue (near $1/2$, where $\cos < 0$). \textbf  {Left:} $M(97) = +1$---more red, the sequence is biased toward the edges. \textbf  {Right:} $M(89) = -2$---more balanced, the bias is weaker. The bridge identity counts the net red-vs-blue imbalance.}}{7}{figure.5}\protected@file@percent }
\newlabel{fig:bias-circle}{{5}{7}{Mertens bias visualized on the circle. Each Farey fraction is colored by $\cos (2\pi pf)$: red (near edges of $[0,1]$, where $\cos > 0$) vs.\ blue (near $1/2$, where $\cos < 0$). \textbf {Left:} $M(97) = +1$---more red, the sequence is biased toward the edges. \textbf {Right:} $M(89) = -2$---more balanced, the bias is weaker. The bridge identity counts the net red-vs-blue imbalance}{figure.5}{}}
