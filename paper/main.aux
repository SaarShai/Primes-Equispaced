\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces How primes break voids. \textbf  {Left:} $\mathcal  {F}_6$ with voids highlighted by size (darker = larger). \textbf  {Center:} prime $p = 7$ inserts one fraction into each of $p - 1 = 6$ distinct gaps (green arcs), filling some voids and skipping others. \textbf  {Right:} composite $N = 8$ leaves voids unfilled (red arcs) due to missing coprime numerators.}}{4}{figure.3}\protected@file@percent }
\newlabel{fig:voids}{{3}{4}{How primes break voids. \textbf {Left:} $\F _6$ with voids highlighted by size (darker = larger). \textbf {Center:} prime $p = 7$ inserts one fraction into each of $p - 1 = 6$ distinct gaps (green arcs), filling some voids and skipping others. \textbf {Right:} composite $N = 8$ leaves voids unfilled (red arcs) due to missing coprime numerators}{figure.3}{}}
