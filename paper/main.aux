\@writefile{lof}{\contentsline {figure}{\numberline {2}{\ignorespaces The wobble visualized on the circle. Dark dots show actual Farey fractions; red circles show ideal (equally spaced) positions. Red arcs connect each fraction to its ideal position---brighter arcs mean larger discrepancy. \textbf  {Left:} $\mathcal  {F}_5$ has high wobble (large gaps between actual and ideal). \textbf  {Center:} $\mathcal  {F}_{12}$ has lower wobble (fractions closer to uniform). \textbf  {Right:} adding prime $p = 13$ (red stars) changes the ideal positions and the wobble.}}{3}{figure.2}\protected@file@percent }
\newlabel{fig:wobble-circle}{{2}{3}{The wobble visualized on the circle. Dark dots show actual Farey fractions; red circles show ideal (equally spaced) positions. Red arcs connect each fraction to its ideal position---brighter arcs mean larger discrepancy. \textbf {Left:} $\F _5$ has high wobble (large gaps between actual and ideal). \textbf {Center:} $\F _{12}$ has lower wobble (fractions closer to uniform). \textbf {Right:} adding prime $p = 13$ (red stars) changes the ideal positions and the wobble}{figure.2}{}}
\@writefile{lof}{\contentsline {figure}{\numberline {3}{\ignorespaces How primes break voids. \textbf  {Left:} $\mathcal  {F}_6$ with voids highlighted by size (darker = larger). \textbf  {Center:} prime $p = 7$ fills every void (green arcs). \textbf  {Right:} composite $N = 8$ leaves voids unfilled (red arcs) due to missing coprime numerators.}}{3}{figure.3}\protected@file@percent }
\newlabel{fig:voids}{{3}{3}{How primes break voids. \textbf {Left:} $\F _6$ with voids highlighted by size (darker = larger). \textbf {Center:} prime $p = 7$ fills every void (green arcs). \textbf {Right:} composite $N = 8$ leaves voids unfilled (red arcs) due to missing coprime numerators}{figure.3}{}}
