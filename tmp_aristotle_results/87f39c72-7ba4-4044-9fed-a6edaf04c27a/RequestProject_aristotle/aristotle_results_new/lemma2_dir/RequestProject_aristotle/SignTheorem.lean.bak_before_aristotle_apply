/-! ## Correlation ratio bounds (open problems, require analytic proof) -/

/-- R(p) > -1 for primes p ≥ 11. Follows from large sieve: |ΣD·δ| << p·(log p)² while
    Σδ² ~ p²/(12π²), giving R = O(log²p / p) → 0. -/
theorem corrRatio_bounded (p : ℕ) (hp : Nat.Prime p) (hp11 : 11 ≤ p) :
    corrRatio p > -1 := by
  sorry

/-- The stronger bound R(p) > -1/2 (needed for B+C > 0).
    Computationally, min R ≈ -0.19 (at p = 11), well above -1/2. -/
theorem corrRatio_gt_neg_half (p : ℕ) (hp : Nat.Prime p) (hp11 : 11 ≤ p) :
    corrRatio p > -1/2 := by
  sorry

/-- For any prime p ≥ 5 with corrRatio p > -1/2, B+C > 0. -/
theorem bPlusC_pos_of_corrRatio_bound (p : ℕ) (hp : Nat.Prime p) (hp5 : 5 ≤ p)
    (hR : corrRatio p > -1/2) :
    bPlusC p > 0 := by
  have h1 := bPlusC_eq_shift_times_oneAddR p hp hp5
  have h2 := shiftSquaredSum_pos p hp hp5
  rw [h1]
  apply mul_pos h2
  linarith

