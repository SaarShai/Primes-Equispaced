theorem sign_theorem_97 : deltaWobble 97 < 0 := by native_decide

/-- ΔW(101) < 0, verified by native_decide. M(101) = 0 (outside hypothesis — ΔW still negative). -/
theorem sign_theorem_101 : deltaWobble 101 < 0 := by native_decide

/-- ΔW(103) < 0, verified by native_decide. M(103) = -2 (outside hypothesis — ΔW still negative). -/
theorem sign_theorem_103 : deltaWobble 103 < 0 := by native_decide

