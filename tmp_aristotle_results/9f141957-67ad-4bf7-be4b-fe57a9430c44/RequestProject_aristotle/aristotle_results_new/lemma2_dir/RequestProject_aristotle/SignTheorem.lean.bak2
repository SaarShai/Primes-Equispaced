theorem sign_theorem_113 : deltaWobble 113 < 0 := by native_decide

/-! ## Ratio Test — weaker sufficient condition -/

/-- The B+C sum: crossTerm(p) + shiftSquaredSum(p).
    B+C > 0 implies ΔW < 0 when combined with D ≥ dilution. -/
def bPlusC (p : ℕ) : ℚ :=
  crossTerm p + shiftSquaredSum p

/-! ## B+C Positivity: computational verification -/

theorem bPlusC_pos_13 : bPlusC 13 > 0 := by native_decide
theorem bPlusC_pos_19 : bPlusC 19 > 0 := by native_decide
theorem bPlusC_pos_31 : bPlusC 31 > 0 := by native_decide
theorem bPlusC_pos_43 : bPlusC 43 > 0 := by native_decide
theorem bPlusC_pos_47 : bPlusC 47 > 0 := by native_decide
theorem bPlusC_pos_53 : bPlusC 53 > 0 := by native_decide
theorem bPlusC_pos_59 : bPlusC 59 > 0 := by native_decide
theorem bPlusC_pos_61 : bPlusC 61 > 0 := by native_decide

/-- **Ratio Test Theorem (statement):**
    If D/A + C/A ≥ 1 (i.e., newDispSquaredSum + shiftSquaredSum ≥ dilution),
    then ΔW(p) < 0. -/
theorem ratio_test (p : ℕ) (hp : Nat.Prime p) (hp5 : 5 ≤ p)
    (h : newDispSquaredSum p + shiftSquaredSum p ≥ dilution p) :
    deltaWobble p < 0 := by
  sorry

/-! ## Key lemma: R = B_raw / δ² is bounded away from -1 -/

/-- The correlation ratio R(p) = crossTerm(p) / (2 · shiftSquaredSum(p)).
    B+C > 0 ⟺ 1 + R > 0 ⟺ R > -1. -/
def corrRatio (p : ℕ) : ℚ :=
  crossTerm p / (2 * shiftSquaredSum p)

/-- **Key structural fact (PROVED):** B+C = δ² · (1 + 2R).
    Since δ² > 0 (StrictPositivity) and R > -1 (to be proved),
    this gives B+C > 0. -/
theorem bPlusC_eq_shift_times_oneAddR (p : ℕ) (hp : Nat.Prime p) (hp5 : 5 ≤ p) :
    bPlusC p = shiftSquaredSum p * (1 + 2 * corrRatio p) := by
  unfold bPlusC corrRatio
  linarith [mul_div_cancel₀ (crossTerm p)
    (show (2 * shiftSquaredSum p) ≠ 0 from
      mul_ne_zero two_ne_zero (ne_of_gt (shiftSquaredSum_pos p hp hp5)))]

/-- Geometric identity: B+C = Σ(D+δ)² - ΣD².
    This means B+C > 0 iff adding δ to D increases the L2 norm.
    Equivalently: the new displacements D_new = D_old + δ have larger
    sum of squares than the old displacements D_old. -/
theorem bPlusC_eq_new_minus_old_sq (p : ℕ) :
    bPlusC p = (∑ ab ∈ fareySet (p - 1),
      (displacement (p - 1) ((ab.1 : ℚ) / ab.2) + shiftFun p ((ab.1 : ℚ) / ab.2)) ^ 2) -
    (∑ ab ∈ fareySet (p - 1),
      (displacement (p - 1) ((ab.1 : ℚ) / ab.2)) ^ 2) := by
  unfold bPlusC;
  unfold crossTerm shiftSquaredSum; norm_num [ add_sq, Finset.sum_add_distrib ] ; ring;
  rw [ add_comm, Finset.sum_mul _ _ _ ]

/-! ## Asymptotic behavior of the correlation ratio R(p) -/

/-- Large sieve bound: R(p) is bounded and approaches 0 as p grows.
    By the large sieve inequality, |ΣD·δ| << p·(log p)²,
    while Σδ² ~ p²/(12π²), giving R = O(log²p / p) → 0. -/
theorem corrRatio_bounded (p : ℕ) (hp : Nat.Prime p) (hp11 : 11 ≤ p) :
    corrRatio p > -1 := by
  sorry

/-- The stronger bound R(p) > -1/2, which is what's actually needed for B+C > 0.
    Computationally, the minimum R ≈ -0.19 (at p = 11), well above -1/2. -/
theorem corrRatio_gt_neg_half (p : ℕ) (hp : Nat.Prime p) (hp11 : 11 ≤ p) :
    corrRatio p > -1/2 := by
  sorry

/-- For any prime p ≥ 5 with corrRatio p > -1, B+C > 0.
    Note: requires R > -1/2 for the conclusion; hypothesis is intentionally weak. -/
theorem bPlusC_pos_of_corrRatio_bound (p : ℕ) (hp : Nat.Prime p) (hp5 : 5 ≤ p)
    (hR : corrRatio p > -1) :
    bPlusC p > 0 := by
  have h1 := bPlusC_eq_shift_times_oneAddR p hp hp5
  have h2 := shiftSquaredSum_pos p hp hp5
  rw [h1]
  -- shiftSquaredSum p > 0; need 1 + 2R > 0, i.e. R > -1/2.
  -- hR gives R > -1, but computationally min R ≈ -0.19 (p=11), well above -1/2.
  sorry

/-! ## corrRatio > -1: computational verification -/

/-- R(11) > -1, verified by native_decide. p=11 is the worst case with R ≈ -0.19. -/
theorem corrRatio_gt_neg1_11 : corrRatio 11 > -1 := by native_decide

/-- R(13) > -1, verified by native_decide. -/
theorem corrRatio_gt_neg1_13 : corrRatio 13 > -1 := by native_decide

/-- R(19) > -1, verified by native_decide. -/
theorem corrRatio_gt_neg1_19 : corrRatio 19 > -1 := by native_decide

/-- R(31) > -1, verified by native_decide. -/
theorem corrRatio_gt_neg1_31 : corrRatio 31 > -1 := by native_decide

/-- R(43) > -1, verified by native_decide. -/
theorem corrRatio_gt_neg1_43 : corrRatio 43 > -1 := by native_decide

/-- R(47) > -1, verified by native_decide. -/
theorem corrRatio_gt_neg1_47 : corrRatio 47 > -1 := by native_decide

/-! ## L2 Norm Increase: Σ(D+δ)² > ΣD² -/

/-- The L2 norm of displacements increases when adding shift δ, for p = 13.
    Equivalently, B + C > 0. Verified computationally. -/
theorem l2_increases_13 :
    (∑ ab ∈ fareySet 12, (displacement 12 ((ab.1 : ℚ) / ab.2) + shiftFun 13 ((ab.1 : ℚ) / ab.2)) ^ 2) >
    (∑ ab ∈ fareySet 12, (displacement 12 ((ab.1 : ℚ) / ab.2)) ^ 2) := by native_decide

/-- The L2 norm of displacements increases when adding shift δ, for p = 19. -/
theorem l2_increases_19 :
    (∑ ab ∈ fareySet 18, (displacement 18 ((ab.1 : ℚ) / ab.2) + shiftFun 19 ((ab.1 : ℚ) / ab.2)) ^ 2) >
    (∑ ab ∈ fareySet 18, (displacement 18 ((ab.1 : ℚ) / ab.2)) ^ 2) := by native_decide

/-- The L2 norm of displacements increases when adding shift δ, for p = 31. -/
theorem l2_increases_31 :
    (∑ ab ∈ fareySet 30, (displacement 30 ((ab.1 : ℚ) / ab.2) + shiftFun 31 ((ab.1 : ℚ) / ab.2)) ^ 2) >
    (∑ ab ∈ fareySet 30, (displacement 30 ((ab.1 : ℚ) / ab.2)) ^ 2) := by native_decide

/-- The L2 norm of displacements increases when adding shift δ, for p = 43. -/
theorem l2_increases_43 :
    (∑ ab ∈ fareySet 42, (displacement 42 ((ab.1 : ℚ) / ab.2) + shiftFun 43 ((ab.1 : ℚ) / ab.2)) ^ 2) >
    (∑ ab ∈ fareySet 42, (displacement 42 ((ab.1 : ℚ) / ab.2)) ^ 2) := by native_decide
