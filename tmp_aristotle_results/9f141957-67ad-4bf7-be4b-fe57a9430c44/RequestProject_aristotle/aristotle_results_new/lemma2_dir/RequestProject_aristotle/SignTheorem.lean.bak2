theorem sign_theorem_79 : deltaWobble 79 < 0 := by native_decide

/-- ΔW(83) < 0, verified by native_decide. M(83) = -4. -/
theorem sign_theorem_83 : deltaWobble 83 < 0 := by native_decide

/-- ΔW(89) < 0, verified by native_decide. M(89) = -2 (outside hypothesis — ΔW still negative). -/
theorem sign_theorem_89 : deltaWobble 89 < 0 := by native_decide

